# Required
NODE_ENV=production
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require
JWT_SECRET=replace-with-at-least-64-random-characters

# Hostinger injects PORT automatically. Do not hardcode it unless support instructs you to.
CORS_ORIGIN=https://achievex.me,https://www.achievex.me
NEXT_PUBLIC_API_URL=https://achievex.me/api/v1

# Optional managed Redis. Leave empty only while testing features that do not require queues/cache.
REDIS_URL=

# Startup behavior
SKIP_DATABASE_MIGRATIONS=false

# Optional integrations
OPENAI_API_KEY=
S3_ENDPOINT=
S3_REGION=
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
