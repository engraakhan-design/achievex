  updatedAt DateTime @updatedAt
  @@index([organizationId, status, nextAttemptAt])
  @@index([runId, createdAt])
}
model IntegrationAutomationApproval {
  id String @id @default(cuid())
  organizationId String
  runId String
  run IntegrationAutomationRun @relation(fields:[runId],references:[id],onDelete:Cascade)
  stepId String
  step IntegrationAutomationStepRun @relation(fields:[stepId],references:[id],onDelete:Cascade)
  status IntegrationAutomationApprovalStatus @default(PENDING)
  requestedByUserId String?
  approverUserId String?
  decidedByUserId String?
  decisionNotes String?
  decidedAt DateTime?
  createdAt DateTime @default(now())
  @@index([organizationId, status, createdAt])
}

enum IntegrationPublisherStatus {
  PENDING
  VERIFIED
  SUSPENDED
  REJECTED
}
enum IntegrationListingType {
  CONNECTOR
  AUTOMATION_TEMPLATE
  WEBHOOK_APP
  API_APP
}
enum IntegrationListingVisibility {
  PRIVATE
  ORGANIZATION
  PUBLIC
}
enum IntegrationListingStatus {
  DRAFT
  IN_REVIEW
  CHANGES_REQUESTED
  PUBLISHED
  SUSPENDED
  ARCHIVED
}
enum IntegrationReviewStatus {
  PENDING
  APPROVED
  CHANGES_REQUESTED
  REJECTED
}
enum IntegrationInstallationStatus {
  ACTIVE
  PAUSED
  ERROR
  UNINSTALLED
}
enum IntegrationCertificationStatus {
  ACTIVE
  EXPIRED
  REVOKED
}
enum IntegrationIncidentStatus {
  OPEN
  INVESTIGATING
  MITIGATED
  RESOLVED
}

model IntegrationPublisher {
  id String @id @default(cuid())
  organizationId String
  ownerUserId String
  name String
  description String?
  websiteUrl String?
  status IntegrationPublisherStatus @default(PENDING)
  verifiedByUserId String?
  verifiedAt DateTime?
  listings IntegrationMarketplaceListing[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  @@unique([organizationId, name])
  @@index([organizationId, status])
}
model IntegrationMarketplaceListing {
  id String @id @default(cuid())
  organizationId String
  publisherId String
  publisher IntegrationPublisher @relation(fields:[publisherId],references:[id],onDelete:Restrict)
  createdByUserId String
  name String
  slug String
  description String?
  type IntegrationListingType
  visibility IntegrationListingVisibility @default(ORGANIZATION)
  status IntegrationListingStatus @default(DRAFT)
  version String
  categories String[] @default([])
  requiredScopes String[] @default([])
  manifest Json?
  submittedAt DateTime?
  publishedAt DateTime?
  reviews IntegrationMarketplaceReview[]
  installations IntegrationInstallation[]
  ratings IntegrationMarketplaceRating[]
  certifications IntegrationCertification[]
  incidents IntegrationMarketplaceIncident[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  @@unique([organizationId, slug, version])
  @@index([organizationId, status, visibility])
}
model IntegrationMarketplaceReview {
  id String @id @default(cuid())
  organizationId String
  listingId String
  listing IntegrationMarketplaceListing @relation(fields:[listingId],references:[id],onDelete:Cascade)
  requestedByUserId String
  reviewedByUserId String?
  status IntegrationReviewStatus @default(PENDING)
  submissionNotes String?
  reviewNotes String?
  findings String[] @default([])
  reviewedAt DateTime?
  createdAt DateTime @default(now())
  @@index([organizationId, status, createdAt])
}
model IntegrationInstallation {
  id String @id @default(cuid())
  organizationId String
  listingId String
  listing IntegrationMarketplaceListing @relation(fields:[listingId],references:[id],onDelete:Restrict)
  installedByUserId String
  updatedByUserId String
  status IntegrationInstallationStatus @default(ACTIVE)
  installedVersion String
  configuration Json?
  autoUpdate Boolean @default(true)
  lastHealthAt DateTime?
  lastError String?
  uninstalledAt DateTime?
  incidents IntegrationMarketplaceIncident[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  @@unique([organizationId, listingId])
  @@index([organizationId, status, updatedAt])
}
model IntegrationMarketplaceRating {
  id String @id @default(cuid())
  organizationId String
  listingId String
  listing IntegrationMarketplaceListing @relation(fields:[listingId],references:[id],onDelete:Cascade)
  userId String
  rating Int
  title String
  body String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  @@unique([organizationId, listingId, userId])
  @@index([listingId, rating])
}
model IntegrationCertification {
  id String @id @default(cuid())
  organizationId String
  listingId String
  listing IntegrationMarketplaceListing @relation(fields:[listingId],references:[id],onDelete:Cascade)
  certifiedByUserId String
  type String
  status IntegrationCertificationStatus @default(ACTIVE)
  validFrom DateTime
  validUntil DateTime?
  evidence Json?
  createdAt DateTime @default(now())
  @@index([organizationId, status, validUntil])
}
model IntegrationMarketplaceIncident {
  id String @id @default(cuid())
  organizationId String
  listingId String
  listing IntegrationMarketplaceListing @relation(fields:[listingId],references:[id],onDelete:Restrict)
  installationId String
  installation IntegrationInstallation @relation(fields:[installationId],references:[id],onDelete:Cascade)
  reportedByUserId String
  resolvedByUserId String?
  title String
  description String?
  severity String
  status IntegrationIncidentStatus @default(OPEN)
  resolution String?
  resolvedAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  @@index([organizationId, status, severity, createdAt])
}
