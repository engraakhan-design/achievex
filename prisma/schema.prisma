  INSTANCE_FAILED
}

model Organization {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  logoUrl     String?
  timezone    String   @default("Asia/Riyadh")
  currency    String   @default("SAR")
  status      OrganizationStatus @default(ACTIVE)
  users       User[]
  departments Department[]
  teams       Team[]
  roles       Role[]
  auditLogs   AuditLog[]
  authTokens  AuthToken[]
  okrCycles   OkrCycle[]
  objectives  Objective[]
  keyResults  KeyResult[]
  initiatives Initiative[]
  domainEvents DomainEvent[]
  notifications Notification[]
  notificationPreferences NotificationPreference[]
  notificationDeliveries NotificationDelivery[]
  apiKeys ApiKey[]
  legacyWebhookSubscriptions LegacyWebhookSubscription[]
  legacyWebhookDeliveries LegacyWebhookDelivery[]
  settings OrganizationSetting[]
  secrets TenantSecret[]
  featureFlags FeatureFlagOverride[]
  branding TenantBranding?
  securityPolicy SecurityPolicy?
  compliancePolicy CompliancePolicy?
  identityProviders IdentityProvider[]
  verifiedDomains VerifiedDomain[]
  scimTokens ScimToken[]
  directoryConnections DirectoryConnection[]
  directorySyncRuns DirectorySyncRun[]
  provisioningEvents ProvisioningEvent[]
  sessions UserSession[]
  aiGenerations AiGeneration[]
  aiFeedback AiFeedback[]
  portfolios Portfolio[]
  programs Program[]
  projects Project[]
  workstreams Workstream[]
  milestones ProjectMilestone[]
  projectTasks ProjectTask[]
  projectDependencies ProjectDependency[]
  projectRisks ProjectRisk[]
  projectIssues ProjectIssue[]
  executionActivities ExecutionActivity[]
  taskComments ProjectTaskComment[]
  taskChecklists ProjectTaskChecklistItem[]
  executionLabels ExecutionLabel[]
  taskLabelLinks ProjectTaskLabel[]
  taskAttachments ProjectTaskAttachment[]
  taskDependencies ProjectTaskDependency[]
  projectObjectiveLinks ProjectObjectiveLink[]
  projectKeyResultLinks ProjectKeyResultLink[]
  resources Resource[]
  resourceTeams ResourceTeam[]
  skills Skill[]
  resourceSkills ResourceSkill[]
  resourceTeamMemberships ResourceTeamMembership[]
  resourceAllocations ResourceAllocation[]
  workingCalendars WorkingCalendar[]
  holidayCalendars HolidayCalendar[]
  availabilityExceptions AvailabilityException[]
  workflowDefinitions WorkflowDefinition[]
  workflowInstances WorkflowInstance[]
  workflowTasks WorkflowTask[]
  workflowHistory WorkflowHistory[]
  approvalRequests ApprovalRequest[]
  approvalStages ApprovalStage[]
  approvalAssignments ApprovalAssignment[]
  approvalDecisions ApprovalDecision[]
  approvalDelegations ApprovalDelegation[]
  approvalEscalations ApprovalEscalation[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  businessRuleDefinitions BusinessRuleDefinition[]
  businessRuleExecutions BusinessRuleExecution[]
  notificationTemplates NotificationTemplate[]
  notificationRoutes NotificationRoute[]
  slaPolicies SlaPolicy[]
  slaClocks SlaClock[]
  slaEscalations SlaEscalation[]
  automationDefinitions AutomationDefinition[]
  automationExecutions AutomationExecution[]
  governanceFrameworks GovernanceFramework[]
  governancePolicies GovernancePolicy[]
  governanceControls GovernanceControl[]
  controlEvidence ControlEvidence[]
  complianceAssessments ComplianceAssessment[]
  riskRecords RiskRecord[]
  riskAssessments RiskAssessment[]
  riskTreatmentPlans RiskTreatmentPlan[]
  controlTests ControlTest[]
  controlTestExecutions ControlTestExecution[]
  complianceFindings ComplianceFinding[]
  correctiveActions CorrectiveAction[]
  accessCertificationCampaigns AccessCertificationCampaign[]
  accessCertificationReviews AccessCertificationReview[]
  accessCertificationDecisions AccessCertificationDecision[]
  sodRules SoDRule[]
  sodViolations SoDViolation[]
  sodExceptions SoDException[]
  accessRequests AccessRequest[]
  accessRequestApprovals AccessRequestApproval[]
  privilegedAssignments PrivilegedAssignment[]
  metricDefinitions MetricDefinition[]
  metricSnapshots MetricSnapshot[]
  analyticsFacts AnalyticsFact[]
  dashboardDefinitions DashboardDefinition[]
  aggregationJobs AggregationJob[]
  dashboardSavedViews DashboardSavedView[]
  predictionModels PredictionModel[]
  predictionRuns PredictionRun[]
  predictionResults PredictionResult[]
  decisionPolicies DecisionPolicy[]
  decisionRecommendations DecisionRecommendation[]
  decisionSimulations DecisionSimulation[]
  enterpriseInsights EnterpriseInsight[]
  insightSubscriptions InsightSubscription[]
  integrationDefinitions IntegrationDefinition[]
  integrationInstances IntegrationInstance[]
  connectorCredentials ConnectorCredential[]
  integrationExecutions IntegrationExecution[]
  integrationHealthRecords IntegrationHealth[]
  businessConnectorProfiles BusinessConnectorProfile[]
  enterpriseConnectorProfiles EnterpriseConnectorProfile[]
  enterpriseConnectorMappings EnterpriseConnectorMapping[]
  enterpriseConnectorSyncItems EnterpriseConnectorSyncItem[]
  collaborationDeliveries CollaborationDelivery[]
  connectorMappings BusinessConnectorMapping[]
  connectorSyncItems ConnectorSyncItem[]
  connectorConflicts ConnectorConflict[]
  apiApplications ApiApplication[]
  apiCredentials ApiCredential[]
  apiProducts ApiProduct[]
  apiProductVersions ApiProductVersion[]
  apiUsageRecords ApiUsageRecord[]

}

model User {
  id              String @id @default(cuid())
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  email           String
  firstName       String
  lastName        String
  jobTitle        String?
  phone           String?
  locale          String @default("en")
  passwordHash    String?
  status          UserStatus @default(INVITED)
  emailVerifiedAt DateTime?
  lastLoginAt     DateTime?
  tokenVersion    Int @default(0)
  departmentId    String?
  department      Department? @relation(fields: [departmentId], references: [id])
  managerId       String?
  manager         User? @relation("UserManager", fields: [managerId], references: [id])
  reports         User[] @relation("UserManager")
  teamMemberships TeamMember[]
  roles           UserRole[]
  auditLogs       AuditLog[]
  authTokens      AuthToken[]
  ownedObjectives Objective[] @relation("ObjectiveOwner")
  ownedKeyResults KeyResult[] @relation("KeyResultOwner")
  checkIns        CheckIn[]
  ownedInitiatives Initiative[] @relation("InitiativeOwner")
  objectiveComments ObjectiveComment[]
  okrActivities   OkrActivity[]
  notifications   Notification[]
  notificationPreference NotificationPreference?
  notificationDeliveries NotificationDelivery[]
  apiKeys ApiKey[]
  legacyWebhookSubscriptions LegacyWebhookSubscription[]
  sessions UserSession[]
  createdIdentityProviders IdentityProvider[] @relation("IdentityProviderCreator")
  createdScimTokens ScimToken[] @relation("ScimTokenCreator")
  aiGenerations AiGeneration[]
  aiFeedback AiFeedback[]
  ownedPortfolios Portfolio[] @relation("PortfolioOwner")
  ownedPrograms Program[] @relation("ProgramOwner")
  ownedProjects Project[] @relation("ProjectOwner")
  sponsoredProjects Project[] @relation("ProjectSponsor")
  ownedWorkstreams Workstream[] @relation("WorkstreamOwner")
  ownedMilestones ProjectMilestone[] @relation("MilestoneOwner")
  assignedProjectTasks ProjectTask[] @relation("ProjectTaskAssignee")
  reportedProjectRisks ProjectRisk[] @relation("ProjectRiskReporter")
  ownedProjectRisks ProjectRisk[] @relation("ProjectRiskOwner")
  reportedProjectIssues ProjectIssue[] @relation("ProjectIssueReporter")
  ownedProjectIssues ProjectIssue[] @relation("ProjectIssueOwner")
  executionActivities ExecutionActivity[] @relation("ExecutionActivityActor")
  projectTaskComments ProjectTaskComment[] @relation("ProjectTaskCommentAuthor")
  uploadedTaskAttachments ProjectTaskAttachment[] @relation("ProjectTaskAttachmentUploader")
  resourceProfile Resource? @relation("ResourceUser")
  ledResourceTeams ResourceTeam[] @relation("ResourceTeamLead")
  resourceTeamMemberships ResourceTeamMembership[] @relation("ResourceTeamMembershipUser")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  @@unique([organizationId, email])
  @@index([organizationId])
  @@index([email])
}

model AuthToken {
  id             String @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  userId         String
  user           User @relation(fields: [userId], references: [id], onDelete: Cascade)
  type           TokenType
  tokenHash      String @unique
  expiresAt      DateTime
  consumedAt     DateTime?
  revokedAt      DateTime?
  replacedById   String?
  createdAt      DateTime @default(now())
  @@index([userId, type])
  @@index([expiresAt])
}

model Department {
  id String @id @default(cuid())
  organizationId String
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name String
  code String?
  description String?
  users User[]
  teams Team[]
  objectives Objective[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  @@unique([organizationId, name])
}

model Team {
  id String @id @default(cuid())
  organizationId String
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  departmentId String?
  department Department? @relation(fields: [departmentId], references: [id])
  name String
  description String?
  members TeamMember[]
  objectives Objective[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  @@unique([organizationId, name])
}

model TeamMember {
  teamId String
  userId String
  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role TeamMemberRole @default(MEMBER)
  joinedAt DateTime @default(now())
  @@id([teamId, userId])
}

model Role {
  id String @id @default(cuid())
  organizationId String
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name String
  description String?
  isSystem Boolean @default(false)
  permissions RolePermission[]
  users UserRole[]
  @@unique([organizationId, name])
}

model Permission {
  id String @id @default(cuid())
  key String @unique
  description String?
  roles RolePermission[]
}

model RolePermission {
  roleId String
  permissionId String
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  @@id([roleId, permissionId])
}

model UserRole {
  userId String
  roleId String
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)
  @@id([userId, roleId])
}

model AuditLog {
  id String @id @default(cuid())
  organizationId String
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  actorUserId String?
  actor User? @relation(fields: [actorUserId], references: [id], onDelete: SetNull)
  action String
  entityType String
  entityId String?
  metadata Json?
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  @@index([organizationId, createdAt])
}


model OkrCycle {
  id             String @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name           String
  description    String?
  startDate      DateTime
  endDate        DateTime
  status         OkrCycleStatus @default(DRAFT)
  isDefault      Boolean @default(false)
  objectives     Objective[]
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  @@unique([organizationId, name])
  @@index([organizationId, status])
}

model Objective {
  id             String @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  cycleId        String
  cycle          OkrCycle @relation(fields: [cycleId], references: [id], onDelete: Cascade)
  title          String
  description    String?
  scope          OkrScope
  status         ObjectiveStatus @default(DRAFT)
  ownerId        String
  owner          User @relation("ObjectiveOwner", fields: [ownerId], references: [id])
  departmentId   String?
  department     Department? @relation(fields: [departmentId], references: [id])
  teamId         String?
  team           Team? @relation(fields: [teamId], references: [id])
  parentId       String?
  parent         Objective? @relation("ObjectiveAlignment", fields: [parentId], references: [id])
  children       Objective[] @relation("ObjectiveAlignment")
  progress       Float @default(0)
  score          Float?
  weight         Float @default(1)
  dueDate        DateTime?
  isPrivate      Boolean @default(false)
  keyResults     KeyResult[]
  comments       ObjectiveComment[]
  activities     OkrActivity[]
  projectLinks   ProjectObjectiveLink[]
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  @@index([organizationId, cycleId])
  @@index([ownerId])
  @@index([parentId])
}

model KeyResult {
  id             String @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  objectiveId    String
  objective      Objective @relation(fields: [objectiveId], references: [id], onDelete: Cascade)
  title          String
  description    String?
  type           KeyResultType
  status         KeyResultStatus @default(NOT_STARTED)
  ownerId        String
  owner          User @relation("KeyResultOwner", fields: [ownerId], references: [id])
  startValue     Float @default(0)
  targetValue    Float @default(100)
  currentValue   Float @default(0)
  unit           String?
  progress       Float @default(0)
  weight         Float @default(1)
  confidence     ConfidenceLevel @default(MEDIUM)
  dueDate        DateTime?
  checkIns       CheckIn[]
  initiatives    Initiative[]
  activities     OkrActivity[]
  projectLinks   ProjectKeyResultLink[]
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  @@index([organizationId, objectiveId])
  @@index([ownerId])
}

model CheckIn {
  id             String @id @default(cuid())
  organizationId String
  keyResultId    String
  keyResult      KeyResult @relation(fields: [keyResultId], references: [id], onDelete: Cascade)
  authorId       String
  author         User @relation(fields: [authorId], references: [id])
  previousValue  Float
  newValue       Float
  progress       Float
  confidence     ConfidenceLevel
  status         KeyResultStatus
  note           String?
  createdAt      DateTime @default(now())
  @@index([organizationId, keyResultId, createdAt])
}

model Initiative {
  id             String @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  keyResultId    String
  keyResult      KeyResult @relation(fields: [keyResultId], references: [id], onDelete: Cascade)
  title          String
  description    String?
  ownerId        String
  owner          User @relation("InitiativeOwner", fields: [ownerId], references: [id])
  status         InitiativeStatus @default(PLANNED)
  progress       Float @default(0)
  startDate      DateTime?
  dueDate        DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  @@index([organizationId, keyResultId])
}

model ObjectiveComment {
  id          String @id @default(cuid())
  objectiveId String
  objective   Objective @relation(fields: [objectiveId], references: [id], onDelete: Cascade)
  authorId    String
  author      User @relation(fields: [authorId], references: [id])
  body        String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  @@index([objectiveId, createdAt])
}

model OkrActivity {
  id             String @id @default(cuid())
  organizationId String
  actorId        String?
  actor          User? @relation(fields: [actorId], references: [id], onDelete: SetNull)
  objectiveId    String?
  objective      Objective? @relation(fields: [objectiveId], references: [id], onDelete: Cascade)
  keyResultId    String?
  keyResult      KeyResult? @relation(fields: [keyResultId], references: [id], onDelete: Cascade)
  action         String
  metadata       Json?
  createdAt      DateTime @default(now())
  @@index([organizationId, createdAt])
  @@index([objectiveId])
  @@index([keyResultId])
}


model DomainEvent {
  id             String @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  eventName      String
  aggregateType  String
  aggregateId    String
  actorUserId    String?
  payload        Json?
  status         DomainEventStatus @default(PENDING)
  attempts       Int @default(0)
  processedAt    DateTime?
  error          String?
  createdAt      DateTime @default(now())
  @@index([organizationId, createdAt])
  @@index([status, createdAt])
}

model Notification {
  id             String @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  userId         String
  user           User @relation(fields: [userId], references: [id], onDelete: Cascade)
  type           NotificationType @default(INFO)
  eventName      String?
  title          String
  body           String
  actionUrl      String?
  metadata       Json?
  readAt         DateTime?
  archivedAt     DateTime?
  createdAt      DateTime @default(now())
  deliveries     NotificationDelivery[]
  @@index([userId, readAt, createdAt])
  @@index([organizationId, createdAt])
}

model NotificationPreference {
  id                    String @id @default(cuid())
  organizationId        String
  organization          Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  userId                String @unique
  user                  User @relation(fields: [userId], references: [id], onDelete: Cascade)
  inAppEnabled          Boolean @default(true)
  emailEnabled          Boolean @default(true)
  checkInReminders      Boolean @default(true)
  riskAlerts            Boolean @default(true)
  assignmentAlerts      Boolean @default(true)
  commentAlerts         Boolean @default(true)
  weeklyDigest          Boolean @default(true)
  reminderDayOfWeek     Int @default(4)
  reminderHour          Int @default(9)
  digestDayOfWeek       Int @default(0)
  digestHour            Int @default(8)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  @@index([organizationId])
}

model NotificationDelivery {
  id             String @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  notificationId String
